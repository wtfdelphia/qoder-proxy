# Copy this file to .env for local use only.
# Do not commit .env or share its contents.

HOST=127.0.0.1
PORT=3000
PROXY_API_KEY=

# CLI backend: "cn" (qoderclicn) or "global" (qodercli)
CLI_BACKEND=cn

# CN backend token (from qoder.com.cn)
QODERCN_PERSONAL_ACCESS_TOKEN=your-cn-token
# Global backend token (from qoder.com, or run `qodercli login`)
QODER_PAT=your-global-token

# Override CLI command auto-detection (optional)
# CLI_COMMAND=

QODERCN_REASONING_EFFORT=
QODERCN_CONTEXT_WINDOW=
QODERCN_MAX_OUTPUT_TOKENS=
QODERCN_TIMEOUT_MS=120000
